{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "installCommand": "npm install",
            "devCommand": "npm run dev",
            "buildCommand": "npm run build",
            "outputDirectory": "dist"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "main:app"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": { "service": "backend" }
        },
        {
            "source": "/(.*)",
            "destination": { "service": "frontend" }
        }
    ]
}
