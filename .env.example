# ============================================
# Variables de entorno — OfertasSuper + MenuIA
# ============================================
# Copia este archivo como .env.local para desarrollo local
# o usa estas variables en el dashboard de Vercel > Settings > Environment Variables
#
# 🔹 BACKEND (servicio "backend" en Vercel)
# ============================================

# PostgreSQL (Neon) — OBLIGATORIO para que funcione en Vercel
# La BD se crea con `create_all` al arrancar el backend
#DATABASE_URL=postgresql://user:***@ep-tu-host.aws.neon.tech/neondb?sslmode=require

# Redis — opcional, se usa para caché
# Si no tienes, el backend funciona igual (sin caché)
#REDIS_URL=redis://localhost:6379

# IA para generar menús semanales
IA_API_URL=https://api.deepseek.com/v1/chat/completions
#IA_API_KEY=sk-tu-api-key-aqui
IA_MODEL=deepseek-chat

# Cookies para scrapers — solo si los usas
# Mercadona NO necesita cookie (API pública)
# Carrefour — requiere cookie de sesión del navegador
#COOKIE_CARREFOUR=tu_cookie_aqui
# Dia — requiere cookie de sesión del navegador
#COOKIE_DIA=tu_cookie_aqui


# 🔹 FRONTEND (servicio "frontend" en Vercel)
# ============================================
# En desarrollo: apunta a tu backend local
# En Vercel: NO la pongas (vacío = mismo dominio, gracias a services + rewrites)
#VITE_API_URL=http://localhost:8000


# 🔹 VERIFICAR DESPUÉS DEL DEPLOY
# ============================================
# 1. Ir a https://tu-app.vercel.app/health  → debe devolver {"estado": "ok"}
# 2. Ir a https://tu-app.vercel.app/ofertas → debe cargar sin errores
# 3. Pulsar "Scrapear Mercadona" → poblar la BD con productos
